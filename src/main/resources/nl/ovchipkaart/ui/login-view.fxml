<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="nl.ovchipkaart.ui.LoginController" styleClass="login-container">
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

    <HBox spacing="10" alignment="TOP_RIGHT">
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="langButton" text="NL" onAction="#onToggleLanguage" prefWidth="40"/>
        <Button fx:id="darkModeButton" text="Dark" onAction="#onToggleDarkMode" prefWidth="50"/>
    </HBox>

    <ImageView fitWidth="120" preserveRatio="true">
        <Image url="@logo.png"/>
    </ImageView>
    <Label text="Binnenlandse Spoorwegen" styleClass="title"/>
    <Label fx:id="subtitleLabel" text="Log in or create an account" styleClass="subtitle"/>

    <Separator/>

    <VBox spacing="8" alignment="CENTER_LEFT" maxWidth="300">
        <Label fx:id="nameLabel" text="Name" styleClass="field-label"/>
        <TextField fx:id="nameField" promptText="Jan de Vries"/>

        <Label fx:id="emailLabel" text="Email" styleClass="field-label"/>
        <TextField fx:id="emailField" promptText="jan@email.nl"/>

        <Label fx:id="passwordLabel" text="Password" styleClass="field-label"/>
        <PasswordField fx:id="passwordField" promptText="password"/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <CheckBox fx:id="personalCheckBox" text="Personal card" selected="true"/>
        </HBox>
    </VBox>

    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="loginButton" text="Login" onAction="#onLogin" styleClass="tap-button" prefWidth="120"/>
        <Button fx:id="registerButton" text="Register" onAction="#onRegister" styleClass="register-button" prefWidth="120"/>
    </HBox>

    <Label fx:id="messageLabel" styleClass="message" wrapText="true" maxWidth="300"/>
</VBox>
